[debug] [2026-04-15T16:27:04.115Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/proposal-management-1d4ec/rulesets {"name":"projects/proposal-management-1d4ec/rulesets/72e98716-a2a9-4261-943d-155ecdc5a867","source":{"files":[{"content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // ─── USERS ───────────────────────────────────────────────\n    // Only the authenticated owner can read/write their own profile.\n    match /users/{userId} {\n      allow read, write: if request.auth != null\n        && request.auth.uid == userId;\n    }\n\n    // ─── TEMPLATES ───────────────────────────────────────────\n    // Only the authenticated owner can CRUD their own templates.\n    match /templates/{templateId} {\n      allow create: if request.auth != null\n        && request.resource.data.userId == request.auth.uid;\n\n      allow read, update, delete: if request.auth != null\n        && resource.data.userId == request.auth.uid;\n    }\n\n    // ─── PROPOSALS ───────────────────────────────────────────\n    // Owner: full CRUD (list queries must filter by userId).\n    // Public: can GET a single doc by ID (client portal).\n    // Public: can UPDATE only status/signature fields.\n    match /proposals/{proposalId} {\n\n      // Anyone with the document ID can read a single proposal.\n      allow get: if true;\n\n      // Only authenticated owner can list (dashboard queries).\n      allow list: if request.auth != null\n        && resource.data.userId == request.auth.uid;\n\n      // Only authenticated owner can create.\n      allow create: if request.auth != null\n        && request.resource.data.userId == request.auth.uid;\n\n      // Only authenticated owner can delete.\n      allow delete: if request.auth != null\n        && resource.data.userId == request.auth.uid;\n\n      // Update: two paths — owner (full) or public (restricted fields).\n      allow update: if\n        // Path 1: Authenticated owner — unrestricted update\n        (request.auth != null && resource.data.userId == request.auth.uid)\n        ||\n        // Path 2: Public (unauthenticated) — restricted to these fields only\n        (\n          request.resource.data.diff(resource.data).affectedKeys()\n            .hasOnly([\"status\", \"signatureType\", \"signatureUrl\", \"signedAt\", \"viewedAt\", \"updatedAt\"])\n          // Immutable fields cannot be tampered with\n          && request.resource.data.userId == resource.data.userId\n          && request.resource.data.templateId == resource.data.templateId\n          && request.resource.data.templateFileUrl == resource.data.templateFileUrl\n          && request.resource.data.templateGdocUrl == resource.data.templateGdocUrl\n          && request.resource.data.clientName == resource.data.clientName\n          && request.resource.data.clientEmail == resource.data.clientEmail\n          && request.resource.data.createdAt == resource.data.createdAt\n        );\n    }\n\n    // ─── NOTIFICATIONS ─────────────────────────────────────────\n    // Read + update: only the authenticated owner (mark as read).\n    // Create/delete: only Cloud Functions via Admin SDK.\n    match /notifications/{notificationId} {\n      allow read: if request.auth != null\n        && resource.data.userId == request.auth.uid;\n      allow update: if request.auth != null\n        && resource.data.userId == request.auth.uid\n        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([\"read\"]);\n      allow create, delete: if false;\n    }\n\n    // ─── ANALYTICS ───────────────────────────────────────────\n    // Read: only the authenticated owner.\n    // Write: only Cloud Functions via Admin SDK (bypasses rules).\n    match /analytics/{userId} {\n      allow read: if request.auth != null\n        && request.auth.uid == userId;\n      allow write: if false;\n    }\n\n    // ─── DENY ALL OTHER PATHS ────────────────────────────────\n    match /{document=**} {\n      allow read, write: if false;\n    }\n  }\n}\n","name":"firestore.rules"}]},"createTime":"2026-04-15T16:27:03.823855Z","metadata":{"services":["cloud.firestore"]}}
