rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── HELPER FUNCTIONS ───────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function getUserRole() {
      return getUserData().role;
    }

    function getUserDept() {
      return getUserData().department;
    }

    function isCeo() {
      return isSignedIn() && getUserRole() == "ceo";
    }

    function isAdmin() {
      return isSignedIn() && getUserRole() == "admin";
    }

    function isAdminOrCeo() {
      return isSignedIn() && getUserRole() in ["admin", "ceo"];
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // ─── USERS ───────────────────────────────────────────────
    // Read:  owner, admin (same dept), or CEO.
    // Write: only the owner can edit their own profile.
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdminOrCeo();
      allow write: if isOwner(userId);
    }

    // ─── DEPARTMENTS ────────────────────────────────────────
    // Read:  any authenticated user (needed for onboarding).
    // Create/delete: admin or CEO only.
    match /departments/{deptId} {
      allow read: if isSignedIn();
      allow create, delete: if isAdminOrCeo();
      allow update: if isAdminOrCeo();
    }

    // ─── ORGANIZATION SETTINGS ───────────────────────────────
    // Only the authenticated owner can read/write their org settings.
    match /orgSettings/{userId} {
      allow read, write: if isOwner(userId);
    }

    // ─── TEMPLATES ───────────────────────────────────────────
    // Read:  owner, admin (same dept via user lookup), or CEO.
    // Create: owner sets themselves as userId.
    // Update/delete: owner, or admin/CEO.
    match /templates/{templateId} {
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;

      allow read: if isSignedIn()
        && (
          resource.data.userId == request.auth.uid
          || isAdminOrCeo()
        );

      allow update, delete: if isSignedIn()
        && (
          resource.data.userId == request.auth.uid
          || isAdminOrCeo()
        );
    }

    // ─── PROPOSALS ───────────────────────────────────────────
    // get:    public (client portal needs to fetch by ID).
    // list:   owner, admin (same department), or CEO.
    // create: owner only, status must be "sent".
    // delete: owner, or admin/CEO.
    // update: owner (full), admin/CEO (full), or public (restricted).
    match /proposals/{proposalId} {

      allow get: if true;

      allow list: if isSignedIn()
        && (
          resource.data.userId == request.auth.uid
          || isCeo()
          || (isAdmin() && resource.data.department == getUserDept())
        );

      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == "sent";

      allow delete: if isSignedIn()
        && (
          resource.data.userId == request.auth.uid
          || isAdminOrCeo()
        );

      allow update: if
        // Path 1: Authenticated owner — unrestricted
        (isSignedIn() && resource.data.userId == request.auth.uid)
        ||
        // Path 2: Admin/CEO — unrestricted (trash, restore, etc.)
        isAdminOrCeo()
        ||
        // Path 3: Public (unauthenticated) — restricted fields only
        (
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(["status", "signatureType", "signatureUrl", "signedAt", "viewedAt", "updatedAt"])
          && (
            (resource.data.status == "sent" && request.resource.data.status in ["viewed", "accepted", "rejected"])
            || (resource.data.status == "viewed" && request.resource.data.status in ["accepted", "rejected"])
          )
          && request.resource.data.userId == resource.data.userId
          && request.resource.data.templateId == resource.data.templateId
          && request.resource.data.templateName == resource.data.templateName
          && request.resource.data.templateFileUrl == resource.data.templateFileUrl
          && request.resource.data.templateGdocUrl == resource.data.templateGdocUrl
          && request.resource.data.clientName == resource.data.clientName
          && request.resource.data.clientEmail == resource.data.clientEmail
          && request.resource.data.fieldValues == resource.data.fieldValues
          && request.resource.data.createdAt == resource.data.createdAt
        );
    }

    // ─── NOTIFICATIONS ─────────────────────────────────────────
    // Read:  owner of the notification, or CEO (global feed).
    // Update: owner only (mark as read).
    // Create/delete: Cloud Functions via Admin SDK only.
    match /notifications/{notificationId} {
      allow read: if isSignedIn()
        && (
          resource.data.userId == request.auth.uid
          || isCeo()
        );
      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["read"]);
      allow create, delete: if false;
    }

    // ─── ANALYTICS ───────────────────────────────────────────
    // Read: owner, or CEO (global view).
    // Write: Cloud Functions via Admin SDK only.
    match /analytics/{userId} {
      allow read: if isOwner(userId) || isCeo();
      allow write: if false;
    }

    // ─── DENY ALL OTHER PATHS ────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
